{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "provider_chain": null,
    "model": "deepseek-ai/DeepSeek-V4-Flash",
    "base_url": "${HORIZON_AI_BASE_URL}",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0.0,
    "analysis_concurrency": 5,
    "enrichment_concurrency": 5,
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Buzzing China",
        "url": "https://china.buzzing.cc/feed.xml",
        "enabled": false,
        "category": "Politics / Current Affairs"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "golang",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    },
    "twitter": null,
    "openbb": null,
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": [
        "Go"
      ],
      "keywords": [],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24,
    "max_items": 25,
    "category_groups": {
      "tech": {
        "name": "Tech",
        "limit": 8,
        "categories": [
          "AI",
          "Programming Languages",
          "Cloud Native",
          "Open Source",
          "technology"
        ]
      },
      "politics": {
        "name": "Politics",
        "limit": 6,
        "categories": [
          "Politics / Current Affairs",
          "politics"
        ]
      },
      "social": {
        "name": "Social Hot Topics",
        "limit": 6,
        "categories": [
          "Social Hot Topics",
          "Social Network Hot Topics",
          "social_hotspot"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 3
  },
  "email": null,
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "platform": "generic",
    "layout": "markdown",
    "request_body": {
      "topic": "${HORIZON_NTFY_TOPIC}",
      "title": "Horizon 每日速递 • #{date}",
      "message": "📊 本日筛选出 **#{important_items}** / #{all_items} 条资讯，以下为精选目录：\n\n#{summary?limit=1500&split=---}\n\n👉 更多详情请点击下方按钮阅读网页版。",
      "priority": 4,
      "tags": [
        "newspaper",
        "chart_with_upwards_trend"
      ],
      "markdown": true,
      "click": "https://cesszlr-horizon.pages.dev/#{date}/summary-#{language}",
      "actions": [
        {
          "action": "view",
          "label": "🌐 网页版完整报告",
          "url": "https://cesszlr-horizon.pages.dev/#{date}/summary-#{language}",
          "clear": true
        }
      ]
    }
  }
}